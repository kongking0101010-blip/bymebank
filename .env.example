# Spring profile (dev | prod | oracle)
SPRING_PROFILES_ACTIVE=dev

# Database (Postgres OR Oracle — switch via SPRING_PROFILES_ACTIVE)
# Postgres example:
DB_URL=jdbc:postgresql://localhost:5432/khmerbank
DB_USER=khmerbank
DB_PASS=khmerbank

# Oracle example (uncomment + set SPRING_PROFILES_ACTIVE=oracle):
# DB_URL=jdbc:oracle:thin:@//localhost:1521/FREEPDB1
# DB_USER=KHMERBANK
# DB_PASS=khmerbank

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# Auth
JWT_SECRET=please-change-me-very-long-secret-min-256-bits-aaaaaaaaaaaaa
API_KEY_ENC=please-change-me-32-byte-aes-key-here

# Public base URL
APP_BASE_URL=http://localhost:8080

# ABA PayWay
ABA_BASE_URL=https://checkout-sandbox.payway.com.kh
ABA_MERCHANT_ID=
ABA_API_KEY=

# ACLEDA Bank
ACLEDA_BASE_URL=https://api-sandbox.acledabank.com.kh
ACLEDA_PARTNER_ID=
ACLEDA_PARTNER_SECRET=

# Wing
WING_BASE_URL=https://sandbox.wingmoney.com
WING_PARTNER_ID=
WING_PARTNER_SECRET=

# Bakong KHQR (direct)
BAKONG_BASE_URL=https://api-bakong.nbc.gov.kh
BAKONG_TOKEN=
BAKONG_MERCHANT_ID=

# Bakong KHQR via the public KhmerBank Payment gateway (preferred — owns the bakong token)
# When VPS_BASE_URL is set, the gateway uses it for /api/check_payment.
# The legacy bare-IP VPS (38.54.93.29) is firewalled to its data centre;
# use the Render gateway instead — same contract, public-internet reachable.
VPS_BASE_URL=https://apicheckpayment.onrender.com
VPS_CUSTOMER_KEY=
VPS_ADMIN_KEY=

# Python bridge (talks to the apicheckpayment Telegram bot)
BRIDGE_URL=http://localhost:8090
BRIDGE_AUTH_TOKEN=replace-me-with-random-40-char-string
