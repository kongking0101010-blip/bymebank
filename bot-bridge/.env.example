# Upstream apicheckpayment Telegram bot
APICHECKING_BOT_URL=https://apicheckpayment.onrender.com

# Server-to-server secret the upstream bot expects in /api/external/issue_key
EXTERNAL_ISSUE_SECRET=replace-me-with-real-secret

# Token Spring sends in X-Bridge-Token to authorise calls to this bridge
BRIDGE_AUTH_TOKEN=replace-me-with-random-40-char-string

# Optional — apicheckpayment ADMIN_KEY, used to fetch admin-uploaded logos
# from /r-admin/logos. Leave empty to disable the /bridge/logos endpoint.
BOT_ADMIN_KEY=

# Listen port (default 8090)
PORT=8090

# Log level: DEBUG | INFO | WARNING
LOG_LEVEL=INFO
